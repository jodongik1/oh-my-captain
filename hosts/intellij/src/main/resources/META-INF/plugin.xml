<idea-plugin>
  <id>com.ohmycaptain</id>
  <name>Oh My Captain</name>
  <vendor>ohmycaptain</vendor>
  <description>Local AI coding agent for IntelliJ</description>

  <depends>com.intellij.modules.platform</depends>
  <depends>com.intellij.modules.lang</depends>
  <depends optional="true">Git4Idea</depends>

  <extensions defaultExtensionNs="com.intellij">
    <applicationService
      serviceImplementation="com.ohmycaptain.core.CoreApplicationService"/>
    <toolWindow
      id="Oh My Captain"
      anchor="right"
      factoryClass="com.ohmycaptain.ui.CaptainToolWindowFactory"
      icon="/icons/captain.svg"/>
  </extensions>

  <actions>
    <group id="com.ohmycaptain.CodeActionGroup"
           class="com.ohmycaptain.actions.CodeActionGroup"
           popup="true"
           text="Oh My Captain">
      <add-to-group group-id="EditorPopupMenu" anchor="last"/>
      <action id="omc.explain"  class="com.ohmycaptain.actions.ExplainCodeAction"     text="Explain This Code"   description="코드 설명"/>
      <action id="omc.review"   class="com.ohmycaptain.actions.ReviewCodeAction"      text="Review This Code"    description="코드 리뷰"/>
      <action id="omc.impact"   class="com.ohmycaptain.actions.ImpactAnalysisAction"  text="Impact Analysis"     description="변경 영향 분석"/>
      <action id="omc.query"    class="com.ohmycaptain.actions.QueryValidationAction" text="Query Validation"    description="SQL 쿼리 검증"/>
      <action id="omc.improve"  class="com.ohmycaptain.actions.ImproveCodeAction"     text="Improve This Code"   description="코드 개선"/>
      <action id="omc.test"     class="com.ohmycaptain.actions.GenerateTestAction"    text="Generate Test"       description="테스트 생성"/>
    </group>
  </actions>
</idea-plugin>
